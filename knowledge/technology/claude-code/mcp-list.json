"mcpServers": {
    "context7": {
        "command": "npx",
        "args": [
            "-y",
            "@upstash/context7-mcp@latest"
        ]
    },
    "linear": {
        "command": "npx",
        "args": [
            "-y",
            "mcp-remote",
            "https://mcp.linear.app/sse"
        ],
        "env": {
            "LINEAR_API_KEY": "<YOUR_LINEAR_API_KEY>"
        }
    },
    "sequential-thinking": {
        "command": "/path/to/local-mcps/mcp-sequential-thinking/.venv/bin/python",
        "args": [
            "-m",
            "mcp_sequential_thinking.server"
        ]
    },
    "mcp-server-firecrawl": {
        "command": "npx",
        "args": [
            "-y",
            "firecrawl-mcp"
        ],
        "env": {
            "FIRECRAWL_API_KEY": "<YOUR_FIRECRAWL_API_KEY>"
        }
    },
    "serena": {
        "type": "stdio",
        "command": "uvx",
        "args": [
            "--from",
            "git+https://github.com/oraios/serena",
            "serena",
            "start-mcp-server",
            "--context",
            "ide-assistant",
            "--project",
            "/path/to/your/project"
        ],
        "env": {}
    },
    "shadcn-ui": {
        "command": "npx",
        "args": [
            "@jpisnice/shadcn-ui-mcp-server",
            "--github-api-key",
            "<YOUR_GITHUB_PAT>"
        ]
    }
}
"mcpServers": {
    "context7": {
        "command": "npx",
        "args": [
            "-y",
            "@upstash/context7-mcp@latest"
        ]
    },
    "linear": {
        "command": "npx",
        "args": [
            "-y",
            "mcp-remote",
            "https://mcp.linear.app/sse"
        ],
        "env": {
            "LINEAR_API_KEY": "<YOUR_LINEAR_API_KEY>"
        }
    },
    "gitmcp": {
        "command": "npx",
        "args": [
            "mcp-remote",
            "https://gitmcp.io/docs"
        ]
    },
    "supabase": {
        "command": "npx",
        "args": [
            "-y",
            "@supabase/mcp-server-supabase@latest",
            "--access-token",
            "<YOUR_SUPABASE_ACCESS_TOKEN>"
        ]
    },
    "zen": {
        "command": "/path/to/local-mcps/zen-mcp-server/.zen_venv/bin/python",
        "args": [
            "/path/to/local-mcps/zen-mcp-server/server.py"
        ]
    },
    "sequential-thinking": {
        "command": "/path/to/local-mcps/mcp-sequential-thinking/.venv/bin/python",
        "args": [
            "-m",
            "mcp_sequential_thinking.server"
        ]
    },
    "playwright": {
        "type": "stdio",
        "command": "npx",
        "args": [
            "@playwright/mcp@latest"
        ],
        "env": {}
    },
    "Ref": {
        "type": "http",
        "url": "https://api.ref.tools/mcp?apiKey=<YOUR_REF_API_KEY>"
    },
    "exa": {
        "command": "npx",
        "args": [
            "-y",
            "mcp-remote",
            "https://mcp.exa.ai/mcp?exaApiKey=<YOUR_EXA_API_KEY>"
        ]
    },
    "memory": {
        "command": "node",
        "args": [
            "/path/to/local-mcps/simple-memory-mcp/index.js"
        ],
        "env": {
            "MEMORY_PATH": "/path/to/memories"
        }
    },
    "shadcn-ui": {
        "command": "npx",
        "args": [
            "@jpisnice/shadcn-ui-mcp-server",
            "--github-api-key",
            "<YOUR_GITHUB_PAT>"
        ]
    },
    "gdrive": {
        "command": "docker",
        "args": [
            "exec",
            "-i",
            "gdrive-mcp-server",
            "node",
            "dist/index.js"
        ],
        "env": {
            "LOG_LEVEL": "silent"
        }
    }
},
"leann-server": {
    "type": "stdio",
    "command": "leann_mcp",
    "args": [],
    "env": {}
},
"serena": {
    "type": "stdio",
    "command": "uvx",
    "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "/path/to/your/project"
    ],
    "env": {}
}
}
}

