# =============================================================================
# Transcript Library — Hosted Environment Variables
# =============================================================================
# Copy this file to /srv/transcript-library/.env.local and fill in the values.
# The deploy script symlinks .env.local into each release directory.
#
# Required vars cause a hard startup failure if missing in hosted mode.
# Optional vars emit a warning or disable a feature gracefully.
# =============================================================================

# -----------------------------------------------------------------------------
# Core — Mode
# -----------------------------------------------------------------------------

# Enable hosted mode. Activates preflight validation for all required vars.
# Required: yes
HOSTED=true

# -----------------------------------------------------------------------------
# Transcript Source
# -----------------------------------------------------------------------------

# Absolute path to the local git checkout of the playlist-transcripts repo.
# Must be a directory containing a valid git work tree.
# Required: yes (hard error in hosted mode)
PLAYLIST_TRANSCRIPTS_REPO=/srv/transcript-library/playlist-transcripts

# Git branch to track for transcript refresh. Used by the daily sweep to
# fast-forward the local checkout. If unset and the checkout is in detached
# HEAD state, a warning is emitted.
# Required: no (warning if detached HEAD and unset)
PLAYLIST_TRANSCRIPTS_BRANCH=master

# Git remote name for the transcript repo. Defaults to "origin" if unset.
# Required: no
# PLAYLIST_TRANSCRIPTS_REMOTE=origin

# -----------------------------------------------------------------------------
# Storage Paths
# -----------------------------------------------------------------------------

# Path to the catalog SQLite database. The directory is also used for
# last-source-refresh.json and last-import-validation.json.
# Required: no (defaults to data/catalog/catalog.db relative to cwd)
CATALOG_DB_PATH=/srv/transcript-library/catalog/catalog.db

# Base directory for insight artifacts (analysis.json, analysis.md, run.json,
# status.json, worker logs). Each video gets a subdirectory by videoId.
# Required: no (defaults to data/insights relative to cwd)
INSIGHTS_BASE_DIR=/srv/transcript-library/insights

# -----------------------------------------------------------------------------
# Authentication — Machine Callers
# -----------------------------------------------------------------------------

# Bearer token for machine-authenticated internal API routes (e.g. /api/insights).
# Must be a strong random token. Without this, machine caller paths return 401.
# Required: yes (hard error in hosted mode)
PRIVATE_API_TOKEN=<strong-random-token>

# Token for the /api/sync-hook endpoint. Webhook callers use this to trigger
# transcript refresh. If unset, sync-hook returns 503 unless the caller uses
# PRIVATE_API_TOKEN instead.
# Required: no (warning in hosted mode)
SYNC_TOKEN=<strong-random-token>

# -----------------------------------------------------------------------------
# Authentication — Browser (Cloudflare Access)
# -----------------------------------------------------------------------------

# Cloudflare Access Application Audience Tag. The app validates the
# cf-access-jwt-assertion header against this audience to trust browser
# requests through Cloudflare Access.
# Required: yes (hard error in hosted mode)
CLOUDFLARE_ACCESS_AUD=<cloudflare-access-audience-tag>

# Cloudflare Access team domain (e.g. myteam.cloudflareaccess.com).
# Used for operator-facing log messages about the browser trust boundary.
# Required: no (warning in hosted mode)
CLOUDFLARE_ACCESS_TEAM_DOMAIN=<team>.cloudflareaccess.com

# -----------------------------------------------------------------------------
# Analysis Provider
# -----------------------------------------------------------------------------

# Which analysis provider to use for transcript analysis.
# Values: "claude-cli" | "openai-cli" | "anthropic-api"
# Required: no (defaults vary by context)
ANALYSIS_PROVIDER=claude-cli

# Claude model override for analysis. Only relevant when ANALYSIS_PROVIDER
# uses Claude.
# Required: no
# CLAUDE_ANALYSIS_MODEL=

# Anthropic API key. This is a separate BILLED API path — not the same as
# being logged into the Claude CLI. Only set this if you intentionally want
# to use the Anthropic API as a provider or fallback.
# Required: no
# ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Deploy Hook
# -----------------------------------------------------------------------------

# GitHub webhook secret for HMAC-SHA256 signature verification on the
# deploy-hook listener (port 9000). The deploy-hook rejects all payloads
# that don't pass signature verification.
# Required: yes (for deploy-hook listener; not validated by app preflight)
DEPLOY_WEBHOOK_SECRET=<github-webhook-secret>
